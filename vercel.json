{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/tracking/cron/daily",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/tracking/cron/weekly",
      "schedule": "30 12 * * 5"
    },
    {
      "path": "/api/tracking/cron/monthly",
      "schedule": "0 13 1 * *"
    }
  ]
}
