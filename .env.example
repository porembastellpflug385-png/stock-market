OPENAI_BASE_URL="https://ai.scd666.com/v1"

# =============================================
# 模型分配（按场景）
# =============================================

# 主模型（默认 / fallback 兜底）
OPENAI_MODEL="gpt-5.4"

# 备用模型（主模型失败时的 fallback）
VERIFIED_TEXT_MODEL="claude-opus-4-6"

# 单次股票分析（/api/analyze） — 用最强模型，不怕慢
ANALYSIS_MODEL="gpt-5.4"

# 日报/周报/月报（/api/tracking/run） — 要快，15s 出结果
TRACKING_MODEL="claude-opus-4-6"

# 扫描精筛（/api/scanner/refine） — JSON 输出，要准
SCANNER_MODEL="gpt-5.4"

# =============================================
# 可选：超时控制
# =============================================

# 单次分析/精筛的 LLM 超时（毫秒，默认 80000 即 80 秒，给 gpt-5.4 留够时间）
LLM_TIMEOUT_MS=80000

